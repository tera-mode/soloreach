# ============================================================
# SoloReach Environment Variables (Example)
# ============================================================
# 1. このファイルをコピーして `.env` または `.env.local` を作る
# 2. すべての値を実値に置き換える
# 3. 絶対に `.env` ファイルをコミットしない（.gitignore 済み）
# 4. 本番では Vercel の Environment Variables で管理する
# ============================================================

# === Firebase / GCP ==========================================
GCP_PROJECT_ID="soloreach-dev"
GCP_LOCATION="asia-northeast1"

# 暫定: Service Account Key (JSON 文字列、Sprint 2 で WIF へ移行)
# 生成手順:
#   1. gcloud iam service-accounts keys create key.json --iam-account=soloreach-vercel@<project>.iam.gserviceaccount.com
#   2. cat key.json でJSON内容を確認、1行にして以下に貼り付け
#   3. ★key.json を削除（rm key.json）
#   4. Vercel Env Vars にも同じ値を登録
# ⚠️ ファイルとしてコミット禁止、Claude Code への入力もしない
# GCP_SERVICE_ACCOUNT_JSON: key.json の内容を1行にしてシングルクォートで囲む
# 例: GCP_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"<KEY>",...}'
GCP_SERVICE_ACCOUNT_JSON='REPLACE_WITH_SERVICE_ACCOUNT_JSON_CONTENT'

# WIF 移行後（Sprint 2 以降に有効化）
# GCP_WIF_PROVIDER="projects/123456789/locations/global/workloadIdentityPools/vercel-pool/providers/vercel-oidc"
# GCP_SERVICE_ACCOUNT_EMAIL="soloreach-vercel@soloreach-prod.iam.gserviceaccount.com"

# Firestore Database ID（デフォルト "(default)"）
FIRESTORE_DATABASE_ID="(default)"

# Cloud Tasks
CLOUD_TASKS_QUEUE_LOCATION="asia-northeast1"

# Cloud Storage
GCS_BUCKET_DRAFTS="soloreach-creative-drafts"
GCS_BUCKET_PUBLIC="soloreach-creative-public"

# OIDC 検証用 (Cloud Tasks タスクの audience)
# Cloud Tasks の OIDC token を検証する際に audience として比較する値
TASKS_OIDC_AUDIENCE="https://soloreach.life"

# === LLM (Gemini) ============================================
GEMINI_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# モデル選択（オプション、デフォルトはコード側）
# GEMINI_MODEL_PRO="gemini-2.5-pro"
# GEMINI_MODEL_FLASH="gemini-2.5-flash"

# === Firebase Auth (管理画面アクセス) ========================
NEXT_PUBLIC_FIREBASE_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="soloreach-dev.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="soloreach-dev"
# 管理画面にアクセス可能な Firebase Auth UID（カンマ区切り）
NEXT_PUBLIC_OWNER_UIDS="abc123,def456"

# === Slack ===================================================
# ⚠️ 開発用と本番用で別アプリを作ること (https://api.slack.com/apps)
SLACK_CLIENT_ID="xxxxxxxxxxxx.xxxxxxxxxxxx"
SLACK_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SLACK_SIGNING_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SLACK_BOT_TOKEN="xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx"
SLACK_NOTIFICATION_CHANNEL="C0XXXXXXXX"

# === X (Twitter) =============================================
# ⚠️ 開発用と本番用で別アプリを作ること (https://developer.x.com/)
# ⚠️ pay-per-use 課金で月予算上限を $10 程度に設定すること
X_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxx"
X_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# === Encryption ==============================================
# AES-256-GCM 用の 32 バイト鍵（base64 エンコード）
# 生成方法: openssl rand -base64 32
ENCRYPTION_KEY="REPLACE_WITH_RANDOM_32_BYTE_BASE64_KEY"

# === Cron (Vercel Cron) ======================================
# Vercel Cron 認証用シークレット
# 生成方法: openssl rand -hex 32
CRON_SECRET="REPLACE_WITH_RANDOM_HEX"

# === Rate Limiting (Upstash) =================================
# (https://upstash.com/) Redis インスタンスを作成
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# === App Settings ============================================
APP_BASE_URL="http://localhost:3000"
APP_NAME="SoloReach"
NODE_ENV="development"
