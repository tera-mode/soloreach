# ─── Node / npm ───────────────────────────────────
node_modules/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Next.js ──────────────────────────────────────
.next/
out/
build/
.vercel/

# ─── Environment Variables ★最重要 ────────────────
# .env.example のみコミット可能。それ以外はすべて Git 除外
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
.env.test

# ─── GCP Service Account Keys ★最重要 ────────────
# 名前にかかわらず、サービスアカウント JSON をコミットしない
*-service-account.json
*-sa-key.json
service-account*.json
sa-key*.json
gcp-key*.json
key.json
.credentials/

# ─── Other Secrets ─────────────────────────────────
secrets/
*.pem
*.key
*.crt
*.p12
*.pfx

# ─── Firebase ─────────────────────────────────────
.firebase/
*-debug.log
firebase-debug.log
firestore-debug.log
ui-debug.log

# ─── TypeScript ──────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Testing artifacts ★公開禁止 ─────────────────
.test-artifacts/
test-results/
playwright-report/
playwright/.cache/
coverage/

# ─── Creative drafts ★公開禁止 ───────────────────
.creative-drafts/

# ─── Editor / OS ─────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ─── Misc ────────────────────────────────────────
tmp/
.tmp/
*.bak
.cache/
