# Disable lifecycle scripts of dependencies (postinstall, etc.)
# This prevents supply-chain attacks via malicious postinstall scripts.
# If a package legitimately requires postinstall, use `npm run` explicitly.
ignore-scripts=true

# Ensure exact version pinning when running `npm install <pkg>`
# (recommended for security, can be overridden per-package if needed)
save-exact=true

# Reject installation if audit shows high/critical vulnerabilities
# Uncomment after initial setup is stable
# audit-level=high
